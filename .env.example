# near-kit-tool-box env example
# Copy to .env and fill in real values (do NOT commit .env)
# =================================================
# Network: testnet (default) or mainnet
export NEAR_NETWORK=testnet
# NEAR_NETWORK=mainnet
# Signing account + key (required for any write tx)
export NEAR_ACCOUNT_ID=alice.testnet
export NEAR_PRIVATE_KEY=ed25519:YOUR_PRIVATE_KEY_HERE
# =================================================
